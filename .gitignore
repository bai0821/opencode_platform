# ═══════════════════════════════════════════════════════════════
# OpenCode Platform - Git Ignore
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
.venv/
venv/
ENV/
env/
.env.local

# ─────────────────────────────────────────────────────────────────
# Node.js / Frontend
# ─────────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
secrets/
credentials/

# ─────────────────────────────────────────────────────────────────
# IDE & Editors
# ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ─────────────────────────────────────────────────────────────────
# OS Generated
# ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────────
# Data & Storage
# ─────────────────────────────────────────────────────────────────
data/
*.db
*.sqlite
*.sqlite3
uploads/
downloads/
temp/
tmp/

# Qdrant Storage
qdrant_storage/
qdrant_data/

# ─────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
log/

# ─────────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────────
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
test-results/
test-reports/

# ─────────────────────────────────────────────────────────────────
# Documentation Build
# ─────────────────────────────────────────────────────────────────
docs/_build/
site/

# ─────────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────────
# Don't ignore docker-compose.yml or Dockerfiles
# But ignore runtime data
docker-data/

# ─────────────────────────────────────────────────────────────────
# SSL Certificates (keep directory structure)
# ─────────────────────────────────────────────────────────────────
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key
!nginx/ssl/.gitkeep

# ─────────────────────────────────────────────────────────────────
# Cache
# ─────────────────────────────────────────────────────────────────
.cache/
*.cache
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────────
# Jupyter Notebooks
# ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─────────────────────────────────────────────────────────────────
# Package Manager Locks (keep these for reproducibility)
# ─────────────────────────────────────────────────────────────────
# package-lock.json  # Keep this
# yarn.lock          # Keep this

# ─────────────────────────────────────────────────────────────────
# Miscellaneous
# ─────────────────────────────────────────────────────────────────
*.bak
*.backup
*.tmp
*.temp
*.old
.history/

# ─────────────────────────────────────────────────────────────────
# Project Specific
# ─────────────────────────────────────────────────────────────────
# Plugin data (keep plugin code, ignore runtime data)
plugins/*/data/
plugins/*/__pycache__/

# User uploaded files
user_uploads/

# Generated files
*.generated.*

# Local configuration overrides
*.local.json
*.local.yaml
config.local.*
